<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <com.example.canvas_for_drawing.CustomSurfaceView
        android:id="@+id/customSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <Button
        android:id="@+id/buttonClean"
        android:layout_width="53dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:text="C"
        app:layout_constraintBottom_toBottomOf="@+id/buttonBack"
        app:layout_constraintStart_toEndOf="@+id/buttonBack"
        app:layout_constraintTop_toTopOf="@+id/buttonBack"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/buttonBack"
        android:layout_width="48dp"
        android:layout_height="51dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="16dp"
        android:text="-"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/buttonNext"
        android:layout_width="53dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:text="->"
        app:layout_constraintBottom_toBottomOf="@+id/buttonClean"
        app:layout_constraintStart_toEndOf="@+id/buttonClean"
        app:layout_constraintTop_toTopOf="@+id/buttonClean"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/buttonNext2"
        android:layout_width="77dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:text="заливка"
        app:layout_constraintBottom_toBottomOf="@+id/buttonNext"
        app:layout_constraintStart_toEndOf="@+id/buttonNext"
        app:layout_constraintTop_toTopOf="@+id/buttonNext" />


</androidx.constraintlayout.widget.ConstraintLayout>